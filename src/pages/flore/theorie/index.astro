---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
// 1. IMPORTATION DU COMPOSANT IMAGE
import { Image } from 'astro:assets';

const definitions = await getCollection('theorie');

const categories = {
  forme_feuille: "Formes des feuilles",
  bord_feuille: "Bords des feuilles",
  nervure: "Nervures des feuilles",
  inflorescence: "Types d'inflorescences"
};
---

<MainLayout title="Atlas Botanique">
  <main class="atlas-container">
    <h1>Atlas Botanique</h1>

    {Object.entries(categories).map(([key, label]) => (
        console.log("Rendering category:", key, "with label:", label), // Debug log
      <section>
        <h2>{label}</h2>
        <div class="grid">
          {definitions
            .filter(item => item.data.categorie === key)
            .map(item => (
              <div class="card-theorie">
                <div class="image-wrapper">
                  <Image 
                    src={item.data.image} 
                    alt={item.data.title}
                    width={400}
                    height={400}
                  />
                  {/* Optionnel : Afficher la 2ème image si elle existe (ex: Capitule) */}
                  {item.data.image2 && (
                    <Image 
                      src={item.data.image2} 
                      alt={item.data.title}
                      width={400}
                      height={400}
                    />
                  )}
                </div>
                <div class="content">
                  <h3>{item.data.title}</h3>
                  <p>{item.data.description}</p>
                </div>
              </div>
            ))}
        </div>
      </section>
    ))}
  </main>
</MainLayout>

<style>
  .atlas-container { max-width: 1000px; margin: 0 auto; padding: 20px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }
  .card-theorie {
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
    background: white;
    transition: transform 0.2s;
  }
  .card-theorie:hover { transform: translateY(-5px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
  .card-theorie img {
    width: 100%;
    height: 150px;
    object-fit: contain;
    background: #f9f9f9;
    padding: 10px;
  }
  .content { padding: 15px; }
  h3 { margin: 0; color: #2e7d32; font-size: 1.1rem; }
  p { font-size: 0.85rem; color: #666; margin-top: 8px; }
</style>
