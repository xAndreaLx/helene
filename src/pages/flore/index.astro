---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// On récupère la collection 'flore' définie dans le config.ts
const toutesLesPlantes = await getCollection('flore');
---

<MainLayout title="Mon Herbier">

  <h2>Théorie</h2>
  <a href="/flore/theorie">Découvrir les formes des feuilles, types d'inflorescences, etc.</a>
    <hr>

  <h2>Ma collection ({toutesLesPlantes.length} plantes)</h2>

  <ul>
    {toutesLesPlantes.map(plante => (
      <li>
        {/* L'URL sera /flore/pissenlit */}
        <a href={`/flore/${plante.id}`}>
          <strong>{plante.data.common_name}</strong> (<i>{plante.data.latin_name}</i>)
        </a>
      </li>
    ))}
  </ul>

  
</MainLayout>
